[sqlfluff]
dialect = postgres
templater = placeholder
exclude_rules =
  # allow use of keywords as identifiers when unambiguous
  references.keywords,
  # TinyPg :paramName syntax conflicts with column qualification rules
  references.consistent,
  # TinyPg :param.attr nested-attribute syntax (e.g. :sensitivityFilter.list)
  # is parsed by sqlfluff as a table-qualified column reference. As of sqlfluff
  # 4.2.0 the placeholder templater no longer suppresses lint violations that
  # overlap a placeholder, so these params now trip references.from.
  references.from,
  # paginated_entries.*::table_type cast not recognized as a table reference
  structure.unused_join,

[sqlfluff:indentation]
indent_unit = tab
indented_ctes = True
indented_joins = True
indented_then = False

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = lower

[sqlfluff:rules:capitalisation.types]
extended_capitalisation_policy = lower

[sqlfluff:rules:convention.terminator]
multiline_newline = False
require_final_semicolon = True

[sqlfluff:templater:placeholder]
param_style = colon

# placeholder values
limit = 20
offset = 0
authContextKeycloakUserId = '00000000-0000-0000-0000-000000000000'
authContextIsAdministrator = false
proposalId = 1
search = ''
createdBy = '00000000-0000-0000-0000-000000000000'
keycloakUserId = '00000000-0000-0000-0000-000000000000'
applicationFormId = 1
batchId = 1
changemakerId = 1
funderShortCode = 'placeholder'
funderCollaborativeShortCode = 'placeholder'
invitedFunderShortCode = 'placeholder'
status = 'pending'
memberFunderShortCode = 'placeholder'
baseFieldShortCode = 'placeholder'
userKeycloakUserId = '00000000-0000-0000-0000-000000000000'
bulkUploadTaskId = 1
isCollaborative = false

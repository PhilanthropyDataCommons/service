[sqlfluff]
dialect = postgres
templater = placeholder
exclude_rules =
  # allow use of keywords as identifiers when unambiguous
  references.keywords,

[sqlfluff:indentation]
indent_unit = tab
indented_ctes = True
indented_joins = True
indented_then = False

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = lower

[sqlfluff:rules:capitalisation.types]
extended_capitalisation_policy = lower

[sqlfluff:rules:convention.terminator]
multiline_newline = False
require_final_semicolon = True

[sqlfluff:templater:placeholder]
param_style = colon

# placeholder values
limit = 20
offset = 0
authContextKeycloakUserId = '00000000-0000-0000-0000-000000000000'
authContextIsAdministrator = false
proposalId = 1
search = ''
createdBy = '00000000-0000-0000-0000-000000000000'
keycloakUserId = '00000000-0000-0000-0000-000000000000'
applicationFormId = 1
batchId = 1
changemakerId = 1
funderShortCode = 'placeholder'
funderCollaborativeShortCode = 'placeholder'
invitedFunderShortCode = 'placeholder'
status = 'pending'
memberFunderShortCode = 'placeholder'
baseFieldShortCode = 'placeholder'
userKeycloakUserId = '00000000-0000-0000-0000-000000000000'

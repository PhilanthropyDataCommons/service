{
	"type": "object",
	"properties": {
		"shortCode": {
			"$ref": "./shortCode.json",
			"readOnly": true
		},
		"name": {
			"type": "string",
			"example": "Example Foundation"
		},
		"keycloakOrganizationId": {
			"$ref": "./keycloakOrganizationId.json"
		},
		"createdAt": {
			"type": "string",
			"format": "date-time",
			"readOnly": true
		},
		"createdBy": {
			"description": "The keycloak user id of the PDC user that created this funder",
			"type": "string",
			"format": "uuid",
			"readOnly": true
		},
		"isCollaborative": {
			"type": "boolean",
			"default": false
		},
		"defaultTerminologySetId": {
			"oneOf": [{ "$ref": "./id.json" }, { "type": "null" }],
			"description": "The terminology set that newly-created opportunities under this funder inherit by default. Null means new opportunities fall back to PDC default labels.",
			"example": 17
		}
	},
	"required": ["shortCode", "name", "createdAt", "createdBy", "isCollaborative"]
}

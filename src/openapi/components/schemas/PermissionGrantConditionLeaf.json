			"type": "string",
			"enum": ["baseFieldCategory"],
			"description": "The entity data field to evaluate the condition against."
		},
		"operator": {
			"type": "string",
			"enum": ["in", "equals"],
			"description": "The comparison operator."
		},
		"value": {
			"oneOf": [
				{
					"type": "string"
				},
				{
					"type": "array",
					"items": {
						"type": "string"
					},
					"minItems": 1
				}
			],
			"description": "The value(s) to compare against."
		}
	},
	"required": ["field", "operator", "value"]
}

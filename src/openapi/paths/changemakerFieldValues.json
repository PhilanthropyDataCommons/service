{
	"get": {
		"operationId": "getChangemakerFieldValues",
		"summary": "Gets a list of changemaker field values.",
		"description": "Returns a paginated list of changemaker field values. Optionally filter by batch or changemaker.",
		"tags": ["Changemaker Field Values"],
		"security": [
			{
				"auth": []
			}
		],
		"parameters": [
			{
				"$ref": "../components/parameters/changemakerFieldValueBatchParam.json"
			},
			{
				"$ref": "../components/parameters/changemakerParam.json"
			}
		],
		"responses": {
			"200": {
				"description": "All changemaker field values matching the filter criteria.",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "../components/schemas/ChangemakerFieldValueBundle.json"
						}
					}
				}
			},
			"401": {
				"$ref": "../components/responses/Unauthorized.json"
			},
			"500": {
				"$ref": "../components/responses/InternalServerError.json"
			}
		}
	},
	"post": {
		"operationId": "addChangemakerFieldValue",
		"summary": "Creates a new field value for a changemaker.",
		"description": "Creates a new field value for an organizational base field for a given changemaker. Multiple values can exist for the same changemaker and field combination.",
		"tags": ["Changemaker Field Values"],
		"security": [
			{
				"auth": []
			}
		],
		"requestBody": {
			"required": true,
			"content": {
				"application/json": {
					"schema": {
						"$ref": "../components/schemas/ChangemakerFieldValue.json"
					}
				}
			}
		},
		"responses": {
			"201": {
				"description": "The new changemaker field value that was created.",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "../components/schemas/ChangemakerFieldValue.json"
						}
					}
				}
			},
			"401": {
				"$ref": "../components/responses/Unauthorized.json"
			},
			"403": {
				"$ref": "../components/responses/Forbidden.json"
			},
			"404": {
				"$ref": "../components/responses/NotFound.json"
			},
			"422": {
				"$ref": "../components/responses/UnprocessableEntity.json",
				"description": "The base field is not an organization-category field, or the base field is forbidden."
			},
			"500": {
				"$ref": "../components/responses/InternalServerError.json"
			}
		}
	}
}

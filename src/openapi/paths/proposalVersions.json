{
	"post": {
		"operationId": "addProposalVersion",
		"summary": "Adds a new proposal version.",
		"tags": ["Proposals"],
		"security": [
			{
				"auth": []
			}
		],
		"requestBody": {
			"required": true,
			"content": {
				"application/json": {
					"schema": {
						"$ref": "../components/schemas/ProposalVersion.json"
					}
				}
			}
		},
		"responses": {
			"201": {
				"description": "The new proposal version that was created, with populated field values",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "../components/schemas/ProposalVersion.json"
						}
					}
				}
			},
			"401": {
				"$ref": "../components/responses/Unauthorized.json"
			},
			"403": {
				"$ref": "../components/responses/Forbidden.json"
			},
			"404": {
				"$ref": "../components/responses/NotFound.json"
			},
			"409": {
				"$ref": "../components/responses/Conflict.json",
				"description": "The proposal version references an application form or field that is not associated with the proposal."
			},
			"500": {
				"$ref": "../components/responses/InternalServerError.json"
			}
		}
	}
}

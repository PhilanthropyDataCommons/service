				}
			},
			"401": {
				"$ref": "../components/responses/Unauthorized.json"
			},
			"404": {
				"$ref": "../components/responses/NotFound.json"
			}
		}
	},
	"delete": {
		"operationId": "deleteSourceById",
		"summary": "Deletes a specific source.",
		"tags": ["Sources"],
		"security": [
			{
				"auth": []
			}
		],
		"parameters": [
			{
				"name": "sourceId",
				"description": "The PDC-generated ID of a source to be deleted.",
				"in": "path",
				"required": true,
				"schema": {
					"$ref": "../components/schemas/id.json"
				}
			}
		],
		"responses": {
			"200": {
				"description": "The deleted source.",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "../components/schemas/Source.json"
						}
					}
				}
			},
			"401": {
				"$ref": "../components/responses/Unauthorized.json"
			},
			"422": {
				"$ref": "../components/responses/UnprocessableEntity.json"
			}
		}

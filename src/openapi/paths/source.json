{
	"get": {
		"operationId": "getSourceById",
		"summary": "Gets a specific source.",
		"tags": ["Sources"],
		"security": [
			{
				"auth": []
			}
		],
		"parameters": [
			{
				"name": "sourceId",
				"description": "The PDC-generated ID of a source.",
				"in": "path",
				"required": true,
				"schema": {
					"$ref": "../components/schemas/id.json"
				}
			}
		],
		"responses": {
			"200": {
				"description": "The source.",

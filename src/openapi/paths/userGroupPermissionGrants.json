{
	"get": {
		"operationId": "getUserGroupPermissionGrants",
		"summary": "Gets a list of v2 permission grants for a user group.",
		"tags": ["Permissions v2"],
		"security": [
			{
				"auth": []
			}
		],
		"parameters": [
			{
				"name": "keycloakOrganizationId",
				"description": "The keycloak organization id of a user group.",
				"in": "path",
				"required": true,
				"schema": {
					"type": "string",
					"format": "uuid"
				}
			},
			{ "$ref": "../components/parameters/pageParam.json" },
			{ "$ref": "../components/parameters/countParam.json" }
		],
		"responses": {
			"200": {
				"description": "A list of permission grants.",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "../components/schemas/UserGroupPermissionGrantBundle.json"
						}
					}
				}
			},
			"404": {
				"$ref": "../components/responses/NotFound.json"
			}
		}
	}
}
